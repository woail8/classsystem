# Spring Boot service port
SERVER_PORT=8080

# MySQL connection
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/campus_learning?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JWT
CAMPUS_JWT_SECRET=change-this-to-a-long-random-secret
CAMPUS_JWT_EXPIRE_HOURS=12

# File storage
CAMPUS_FILE_UPLOAD_PATH=./server-data/uploads

# MySQL container init
MYSQL_DATABASE=campus_learning
MYSQL_ROOT_PASSWORD=123456
